# Copier vers .env et renseigner les valeurs (ne pas commiter .env)
# cp .env.example .env

# --- API FastAPI (optionnel, utile pour scripts / docker) ---
# HOST=0.0.0.0
# PORT=8000

# Origines autorisées pour CORS (séparateur virgule si plusieurs)
CORS_ORIGINS=http://localhost:3000

# --- OpenHosta (modèle distant type OpenAI) ---
# Doc : https://github.com/hand-e-fr/OpenHosta#option-b-remote-api-openai
# Verbosité logs applicatifs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

OPENHOSTA_DEFAULT_MODEL_NAME=gpt-4.1
OPENHOSTA_DEFAULT_MODEL_API_KEY=
# OPENHOSTA_DEFAULT_MODEL_BASE_URL=https://api.openai.com/v1

# Pour un fournisseur compatible OpenAI (ex. autre endpoint), décommenter et adapter BASE_URL + clé.

# --- Open data (D1–D3) — contexte injecté avant OpenHosta sur /api/v1/analyze ---
# true | false — désactiver pour éviter tout appel HTTP sortant depuis l’API
ENABLE_OPENDATA_CONTEXT=true
# Timeout secondes pour CNAV + data.gouv
# OPENDATA_TIMEOUT=15
# User-Agent des requêtes open data (recommandé en production)
# RETROAIDE_HTTP_USER_AGENT=RetroAide/0.1 (+https://votre-depot)

# --- D4 — POST /internal/context (prévisualisation du bloc LLM, sans modèle) ---
# Laisser vide pour désactiver l’endpoint (réponse 503). En dev : un secret local fort.
# INTERNAL_API_TOKEN=
